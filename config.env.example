# Copy this file to config.env and fill in the values before running run.sh.
# config.env is ignored by git because it contains secrets.

# Telegram setup.
TELEGRAM_BOT_TOKEN=replace-me
ALLOWED_TELEGRAM_USER_IDS=123456789

# OpenAI setup.
OPENAI_API_KEY=replace-me
OPENAI_MAIN_MODEL=gpt-5.1
OPENAI_TITLE_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_CONTEXT_WINDOW_TOKENS=270000
OPENAI_TIMEOUT_SECONDS=90

# Local app setup.
DATABASE_URL=sqlite:///data/telegram_gpt_bot.db
LOG_LEVEL=INFO
TELEGRAM_FILE_SIZE_LIMIT_MB=20
DEFAULT_STICKER_FILE_ID=CAACAgQAAxkBAAEQ8fVp4vqqCT9aBQmZK2iVdB1-ILgauwAC_gwAAhexSFBbzkvZt_rnPzsE
